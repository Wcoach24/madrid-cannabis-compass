{
  "trailingSlash": false,
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Link",
          "value": "<https://sdpmwelfkseuhlhgatsc.supabase.co>; rel=preconnect; crossorigin, <https://fonts.googleapis.com>; rel=preconnect, <https://fonts.gstatic.com>; rel=preconnect; crossorigin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(club|guide|district|clubs|es|de|fr|it)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "permanent": true
    },
    {
      "source": "/club/chamberi-club-social-madrid",
      "destination": "/club/vallehermoso-club-social-madrid",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://sdpmwelfkseuhlhgatsc.supabase.co/functions/v1/generate-sitemap"
    },
    {
      "source": "/api/rss",
      "destination": "https://sdpmwelfkseuhlhgatsc.supabase.co/functions/v1/generate-rss"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
